// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth.js required models
model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum UserAccountType {
  INDIVIDUAL
  BUSINESS
}

model User {
  id            String          @id @default(uuid())
  name          String?
  email         String          @unique
  emailVerified DateTime?
  image         String?
  googleId      String?         @unique @map("google_id")
  password      String? // For email/password authentication
  role          String          @default("USER") // USER, ADMIN
  accountType   UserAccountType @default(INDIVIDUAL) @map("account_type")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  // Relations
  accounts          Account[]
  sessions          Session[]
  carbonActivities  CarbonActivity[]
  digitalActivities DigitalActivity[]
  goals             Goal[]
  userSettings      UserSettings?
  teamMemberships   TeamMember[]
  achievements      Achievement[]
  aiInsights        AiInsight[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Carbon tracking models
model CarbonActivity {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  activityType  String   @map("activity_type") // transportation, digital, etc.
  category      String? // car, streaming, etc.
  description   String?
  carbonFootprint Float  @map("carbon_footprint") // kg CO2
  unit          String   @default("kg_co2")
  activityDate  DateTime @default(now()) @map("activity_date")
  source        String   @default("manual") // manual, extension, api
  metadata      Json?    // JSON for additional data
  aiEnhanced    Boolean  @default(false) @map("ai_enhanced")
  aiConfidence  Float?   @map("ai_confidence")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activities")
}

// Digital activities for web tracking (from Chrome extension)
model DigitalActivity {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  domain          String
  pageTitle       String?  @map("page_title")
  durationMinutes Int      @default(0) @map("duration_minutes")
  activityType    String?  @map("activity_type") // STREAMING, SEARCH, etc.
  intensityLevel  String   @default("medium") @map("intensity_level") // low, medium, high
  carbonFootprint Float    @default(0) @map("carbon_footprint")
  sessionId       String?  @map("session_id")
  timestamp       DateTime @default(now())
  metadata        Json?
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("digital_activities")
}

model Goal {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  goalType     String   @map("goal_type")
  targetValue  Float    @map("target_value") // Target value
  currentValue Float    @default(0) @map("current_value") // Current progress
  unit         String   @default("kg_co2") // kg CO2, %, etc.
  startDate    DateTime @map("start_date")
  endDate      DateTime @map("end_date")
  status       String   @default("active") // active, completed, paused
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("goals")
}

// AI insights for enhanced recommendations
model AiInsight {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  insightType    String    @map("insight_type")
  title          String
  content        String
  confidenceScore Float?   @map("confidence_score")
  impactScore    Float?    @map("impact_score")
  category       String?
  status         String    @default("active") // active, dismissed, expired
  generatedAt    DateTime  @default(now()) @map("generated_at")
  expiresAt      DateTime? @map("expires_at")
  metadata       Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_insights")
}

model UserSettings {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  notifications      Boolean  @default(true)
  emailNotifications Boolean  @default(true) @map("email_notifications")
  theme              String   @default("dark") // dark, light
  timezone           String   @default("UTC")
  carbonUnit         String   @default("kg") @map("carbon_unit") // kg, g, tons
  privacyLevel       String   @default("private") @map("privacy_level") // private, public, team
  weeklyReports      Boolean  @default(true) @map("weekly_reports")
  monthlyReports     Boolean  @default(true) @map("monthly_reports")
  goalReminders      Boolean  @default(true) @map("goal_reminders")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model Achievement {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  achievementType String   @map("achievement_type") // e.g., 'FIRST_ACTIVITY', 'REDUCED_EMISSIONS_STREAK'
  title           String
  description     String?
  icon            String?
  points          Int      @default(0)
  unlockedAt      DateTime @default(now()) @map("unlocked_at")
  metadata        Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementType])
  @@map("achievements")
}

// Team/Organization models (for future use)
model Team {
  id          String   @id @default(uuid())
  name        String
  description String?
  slug        String   @unique
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members TeamMember[]

  @@map("teams")
}

model TeamMember {
  id       String   @id @default(uuid())
  userId   String   @map("user_id")
  teamId   String   @map("team_id")
  role     String   @default("MEMBER") // ADMIN, MEMBER, VIEWER
  joinedAt DateTime @default(now()) @map("joined_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@map("team_members")
}
