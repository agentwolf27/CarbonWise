# Authentication Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-nextauth-key-here

# Google OAuth Configuration
# Web App OAuth (for Next.js app)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Chrome Extension OAuth (separate client ID)
EXTENSION_GOOGLE_CLIENT_ID=your-extension-google-oauth-client-id.apps.googleusercontent.com

# DeepSeek API Configuration (via OpenRouter)
DEEPSEEK_API_KEY=your-openrouter-api-key

# Database Configuration - CHOOSE ONE:

# Option 1: Google Cloud SQL (RECOMMENDED - uses your $300 credit)
# DATABASE_URL=postgresql://username:password@your-cloud-sql-ip:5432/carbonwise
# Example: DATABASE_URL=postgresql://carbonwise_user:your_password@34.123.45.67:5432/carbonwise

# Option 2: Supabase (if you prefer easier setup)
# SUPABASE_URL=your-supabase-project-url
# SUPABASE_ANON_KEY=your-supabase-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Environment
NODE_ENV=development

# Optional: Climatiq API for enhanced carbon data
CLIMATIQ_API_KEY=your-climatiq-api-key-here

# Optional: For advanced analytics
MIXPANEL_TOKEN=your-mixpanel-token-here
GOOGLE_ANALYTICS_ID=your-ga-tracking-id
